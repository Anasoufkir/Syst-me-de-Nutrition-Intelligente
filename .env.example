# =============================================================================
# Système de Nutrition Intelligente — Variables d'Environnement
# =============================================================================
# Copier ce fichier en .env et adapter les valeurs à votre environnement.
# Ne jamais committer le fichier .env dans le dépôt git.
# =============================================================================

# -----------------------------------------------------------------------------
# SERVEUR
# -----------------------------------------------------------------------------

# Port d'écoute du serveur HTTP
PORT=3000

# Environnement d'exécution : development | production | test
NODE_ENV=development

# Hôte d'écoute (0.0.0.0 pour écouter sur toutes les interfaces)
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# API
# -----------------------------------------------------------------------------

# Préfixe de toutes les routes API
API_PREFIX=/api

# Version de l'API (utilisée dans les routes : /api/v1/...)
API_VERSION=v1

# -----------------------------------------------------------------------------
# SÉCURITÉ
# -----------------------------------------------------------------------------

# Rate limiting — fenêtre de temps en millisecondes (défaut : 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Rate limiting — nombre maximum de requêtes par fenêtre et par IP
RATE_LIMIT_MAX=100

# CORS — origines autorisées (séparées par des virgules, * pour tout autoriser)
# Exemple production : CORS_ORIGINS=https://monapp.com,https://api.monapp.com
CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------

# Niveau de log : error | warn | info | debug
LOG_LEVEL=info

# Format des logs : json (production) | pretty (développement)
LOG_FORMAT=pretty

# -----------------------------------------------------------------------------
# DOCUMENTATION API (Swagger)
# -----------------------------------------------------------------------------

# Activer Swagger UI : true | false
# Recommandé : false en production
SWAGGER_ENABLED=true

# Chemin vers la documentation Swagger UI
SWAGGER_PATH=/api/docs
